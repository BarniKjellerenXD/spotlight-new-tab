{
  "manifest_version": 3,
  "name": "Spotlight New Tab",
  "version": "1.0",
  "description": "A spotlight-style search overlay for the new tab page, inspired by Zen Browser and Vivaldi Ctrl+E.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "history",
    "topSites",
    "tabs",
    "storage",
    "search"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
