{
  "manifest_version": 3,
  "name": "Spotlight New Tab",
  "short_name": "Spotlight",
  "version": "1.0.0",
  "description": "A beautiful spotlight-style search overlay for your new tab page. Search bookmarks, history, open tabs, and the web — instantly.",
  "homepage_url": "https://github.com/BarniKjellerenXD/spotlight-new-tab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "activeTab",
    "bookmarks",
    "history",
    "topSites",
    "tabs",
    "storage",
    "search",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "open-spotlight": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Open Spotlight Search overlay"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Spotlight Search (Ctrl+E)"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
